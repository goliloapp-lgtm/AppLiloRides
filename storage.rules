rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Reglas para imágenes de perfil de pasajeros y conductores
    match /profile-images/{userId}/{fileName} {
      // Permitir lectura pública para que otros usuarios (conductores/pasajeros) puedan ver la foto
      allow read: if true;
      
      // Permitir escribir solo si el usuario está autenticado y es dueño del archivo (su UID coincide con userId)
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regla de respaldo para otros archivos (requiere estar autenticado)
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
